      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<main id="main">

<!-- ============ 1. HERO ============ -->
<section class="hero" id="top" aria-label="Intro">
  <div class="hero-fallback" aria-hidden="true"></div>
  <canvas id="heroCanvas" aria-hidden="true"></canvas>
  <div class="hero-vignette" aria-hidden="true"></div>

  <div class="hero-content">
    <div class="hero-logo" id="heroLogo3d" role="img" aria-label="The IronPeak mark">
      <img src="{{ 'ip-hq-logo.svg' | asset_url }}" alt="" loading="eager" decoding="async">
    </div>
    <p class="hero-label"><span class="pk">▲</span> Dealer Program — Permanent Roofline Lighting <span class="pk">▲</span></p>
    <h1 class="hero-h1" id="heroH1">
      <span class="h1-line">Permanent lighting</span>
      <span class="h1-line">without the</span>
      <span class="h1-line"><span class="gate-x" id="gateX">$20,000</span> gate.</span>
    </h1>
    <p class="hero-sub">Every other brand charges $20K+ to get in, then sells you the training on top. We charge nothing, train you free, and let the margins do the talking.</p>
    <div class="hero-ctas">
      <a class="btn btn-primary mag" href="https://ironpeaklighting.com/pages/profit-calculator">Run the profit calculator <span class="arr">→</span></a>
      <a class="btn btn-ghost mag" href="https://ironpeaklighting.com/pages/dealer-program">Apply to become a dealer <span class="arr">→</span></a>
    </div>
    <p class="hero-meta">
      <span><b>$0</b> buy-in</span>
      <span><b>Free</b> training</span>
      <span><b>$30+/ft</b> installed</span>
      <span><b>No</b> lock-in</span>
    </p>
  </div>

  <p class="hero-scroll" aria-hidden="true">Scroll</p>
</section>

<!-- ============ TICKER ============ -->
<div class="ticker" aria-hidden="true">
  <div class="ticker-track">
    <div class="ticker-group">
      <span class="ti">Christmas-light installers</span><span class="tsep">▲</span>
      <span class="ti">Security &amp; low-voltage</span><span class="tsep">▲</span>
      <span class="ti">Window cleaning &amp; exterior</span><span class="tsep">▲</span>
      <span class="ti">Landscape lighting</span><span class="tsep">▲</span>
      <span class="ti hot">$0 buy-in</span><span class="tsep">▲</span>
      <span class="ti hot">Free training</span><span class="tsep">▲</span>
      <span class="ti">No lock-in</span><span class="tsep">▲</span>
      <span class="ti hot">TrueCenter Apex — patent pending</span><span class="tsep">▲</span>
    </div>
    <div class="ticker-group">
      <span class="ti">Christmas-light installers</span><span class="tsep">▲</span>
      <span class="ti">Security &amp; low-voltage</span><span class="tsep">▲</span>
      <span class="ti">Window cleaning &amp; exterior</span><span class="tsep">▲</span>
      <span class="ti">Landscape lighting</span><span class="tsep">▲</span>
      <span class="ti hot">$0 buy-in</span><span class="tsep">▲</span>
      <span class="ti hot">Free training</span><span class="tsep">▲</span>
      <span class="ti">No lock-in</span><span class="tsep">▲</span>
      <span class="ti hot">TrueCenter Apex — patent pending</span><span class="tsep">▲</span>
    </div>
  </div>
</div>

<!-- ============ 2. ROOFLINE IGNITION v2 (pinned scrub) ============ -->
<section class="ignite" id="proof" aria-label="Roofline ignition">
  <div class="ignite-stage">
    <svg class="ignite-svg" id="houseSvg" viewBox="0 0 1000 460" fill="none" role="img" aria-label="A symmetric three-gable house roofline lighting up, with an LED landing dead center on every peak">
      <defs>
        <radialGradient id="g-blue">
          <stop offset="0%"  stop-color="#eaf3ff" stop-opacity="0.95"/>
          <stop offset="30%" stop-color="#1E7FFF" stop-opacity="0.5"/>
          <stop offset="100%" stop-color="#1E7FFF" stop-opacity="0"/>
        </radialGradient>
        <radialGradient id="g-white">
          <stop offset="0%"  stop-color="#ffffff" stop-opacity="0.95"/>
          <stop offset="30%" stop-color="#cfe2ff" stop-opacity="0.5"/>
          <stop offset="100%" stop-color="#cfe2ff" stop-opacity="0"/>
        </radialGradient>
        <radialGradient id="g-silver">
          <stop offset="0%"  stop-color="#f2f5fa" stop-opacity="0.95"/>
          <stop offset="30%" stop-color="#c9d4e4" stop-opacity="0.5"/>
          <stop offset="100%" stop-color="#c9d4e4" stop-opacity="0"/>
        </radialGradient>
        <radialGradient id="g-red">
          <stop offset="0%"  stop-color="#ffe2e6" stop-opacity="0.95"/>
          <stop offset="30%" stop-color="#ff2d3f" stop-opacity="0.5"/>
          <stop offset="100%" stop-color="#ff2d3f" stop-opacity="0"/>
        </radialGradient>
        <radialGradient id="bloomGrad" cx="50%" cy="50%" r="50%">
          <stop offset="0%"  stop-color="#1E7FFF" stop-opacity="0.32"/>
          <stop offset="55%" stop-color="#155BF2" stop-opacity="0.12"/>
          <stop offset="100%" stop-color="#155BF2" stop-opacity="0"/>
        </radialGradient>
      </defs>

      <!-- bloom under the roof -->
      <ellipse id="bloomGlow" cx="500" cy="265" rx="470" ry="195" fill="url(#bloomGrad)" opacity="0"/>

      <!-- faint structure -->
      <g stroke="#2a3140" stroke-width="1.5">
        <line x1="0" y1="420" x2="1000" y2="420" opacity="0.35"/>
        <line x1="60"  y1="362" x2="60"  y2="418" opacity="0.3"/>
        <line x1="940" y1="362" x2="940" y2="418" opacity="0.3"/>
        <line x1="355" y1="302" x2="355" y2="418" opacity="0.16"/>
        <line x1="645" y1="302" x2="645" y2="418" opacity="0.16"/>
        <rect x="478" y="352" width="44" height="66" opacity="0.3"/>
        <rect class="win" x="160" y="348" width="58" height="42" opacity="0.35" fill="#cfe2ff" fill-opacity="0"/>
        <rect class="win" x="782" y="348" width="58" height="42" opacity="0.35" fill="#cfe2ff" fill-opacity="0"/>
        <rect class="win" x="384" y="346" width="50" height="44" opacity="0.3"  fill="#cfe2ff" fill-opacity="0"/>
        <rect class="win" x="566" y="346" width="50" height="44" opacity="0.3"  fill="#cfe2ff" fill-opacity="0"/>
      </g>

      <!-- the roofline: eave → gable apex → valley → CENTER apex (x=500) → valley → gable apex → eave -->
      <path id="roofPath" d="M 60 360 L 230 215 L 355 300 L 500 130 L 645 300 L 770 215 L 940 360"
            stroke="#3a4a6b" stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round"/>

      <!-- LEDs injected by JS (per-segment spacing — every apex gets a bulb) -->
      <g id="ledLayer"></g>

      <!-- TrueCenter callout -->
      <g id="apexLabel" opacity="0">
        <line x1="514" y1="118" x2="610" y2="64" stroke="#1E7FFF" stroke-width="1.5" opacity="0.85"/>
        <circle cx="514" cy="118" r="2.5" fill="#1E7FFF"/>
        <text x="620" y="56" class="lab-hot">TrueCenter Apex — dead center.</text>
        <text x="620" y="78">Every time.</text>
      </g>
    </svg>

    <div class="ignite-copy">
      <h2 class="ignite-h" id="igniteH">Make every roofline look like this.</h2>
      <p class="ignite-sub">A perfect, symmetrical peak in under 5 minutes — <b>and 16 million colors once it's up.</b> One system, every holiday.</p>
      <div class="mode-row" role="group" aria-label="LED color modes" id="modeRow">
        <button class="chip" type="button" data-mode="white" aria-pressed="false">Arctic White</button>
        <button class="chip" type="button" data-mode="blue" aria-pressed="false">IronPeak Blue</button>
        <button class="chip" type="button" data-mode="chase" aria-pressed="false">Chase</button>
        <button class="chip" type="button" data-mode="gameday" aria-pressed="false">Game Day</button>
      </div>
      <p class="mode-cap">RGBW — <b>16M colors and a true white.</b> One system, every holiday.</p>
    </div>
  </div>
</section>

<!-- ============ 3. THE PRODUCT, DOING THE WORK ============ -->
<section class="work sec-pad" id="work" aria-label="The product">
  <div class="wrap">
    <p class="sec-label"><span class="lab-n">01</span> The Product</p>
    <h2 class="h2">The product, <span class="accent">doing the work.</span></h2>

    <div class="work-grid">
      <div class="video-frame" data-reveal>
        <p class="vf-tag">Field footage</p>
        <video src="{{ 'ip-hq-hero-video.mp4' | asset_url }}" muted autoplay loop playsinline preload="metadata" aria-label="IronPeak permanent roofline lighting in action"></video>
        <p class="vf-status"><i></i> Live loop</p>
      </div>
      <aside class="work-aside" data-reveal>
        <h3>TrueCenter <span class="accent">Apex Track</span></h3>
        <p>Pre-made, pitch-matched peak components. A perfect symmetrical peak goes up in <b style="color:var(--steel-1)">under 5 minutes</b> — not 25 of cutting and guessing on a ladder.</p>
        <ul class="spec-list">
          <li><span class="k">Peak install</span><span class="v"><em>&lt;5</em> min</span></li>
          <li><span class="k">Splicing</span><span class="v">None</span></li>
          <li><span class="k">Fit</span><span class="v">Pitch-matched</span></li>
          <li><span class="k">Connection</span><span class="v">Plug-and-play</span></li>
        </ul>
      </aside>
    </div>

