<!-- ============ THE VAULT — email gate ============ -->
<script>
(function () {
  /* Lead capture — GoHighLevel is the primary CRM (inbound-webhook workflow;
     automations key off `source`). HubSpot kept as a dual-write backstop during
     the transition — delete the HubSpot entry in `sends` (and PORTAL/FORM) to
     cut over fully. HubSpot payload stays email-only: that form rejects the
     whole submission if it receives a field it doesn't have. */
  var GHL_WEBHOOK = 'https://services.leadconnectorhq.com/hooks/99eVuuXW11CRRtiGwcXE/webhook-trigger/5b7b3d77-8087-4f57-999f-a13bf0580e0c';
  var PORTAL = '246087675';
  var FORM = '227f991a-f1ea-478d-992f-c1b4efcf4959';
  var KEY = 'ip_vault_unlock';

  var grid = document.getElementById('vaultGrid');
  var gate = document.getElementById('vaultGate');
  var form = document.getElementById('vaultForm');
  var email = document.getElementById('vaultEmail');
  var success = document.getElementById('vaultSuccess');
  if (!grid || !gate || !form || !email) return;

  function saved() { try { return localStorage.getItem(KEY) === '1'; } catch (e) { return false; } }
  function save(em) { try { localStorage.setItem(KEY, '1'); if (em) localStorage.setItem('ip_lead', JSON.stringify({ email: em, ts: Date.now() })); } catch (e) { /* private mode — session-only unlock */ } }

  function unlock(returning) {
    grid.classList.remove('locked');
    grid.removeAttribute('inert');
    grid.removeAttribute('aria-hidden');
    gate.classList.add('gone');
    gate.setAttribute('aria-hidden', 'true');
    if (!returning && success) success.classList.add('show');
  }

  if (window.IP_CUSTOMER && window.IP_CUSTOMER.email) { save(window.IP_CUSTOMER.email); unlock(true); return; }
  if (saved()) { unlock(true); return; }
  try { var IPL = JSON.parse(localStorage.getItem('ip_lead') || 'null'); if (IPL && IPL.email) email.value = IPL.email; } catch (e) { /* ignore */ }

  form.addEventListener('submit', function (e) {
    e.preventDefault();
    if (!email.checkValidity()) { email.reportValidity(); return; }
    var btn = form.querySelector('button');
    btn.disabled = true;
    btn.textContent = 'Unlocking…';
    var SOURCE = 'IronPeak Dealer Vault — Sales Modules';
    var sends = [
      fetch(GHL_WEBHOOK, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: email.value, source: SOURCE })
      }),
      fetch('https://api.hsforms.com/submissions/v3/integration/submit/' + PORTAL + '/' + FORM, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          fields: [{ name: 'email', value: email.value }],
          context: { pageName: SOURCE }
        })
      })
    ];
    /* unlock regardless of network outcome — never punish a visitor for our errors */
    Promise.all(sends.map(function (p) { return p.catch(function () {}); }))
      .then(function () { save(email.value); unlock(false); });
  });
})();
</script>

