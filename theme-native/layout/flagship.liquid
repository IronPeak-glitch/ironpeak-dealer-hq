<script src="https://cdn.jsdelivr.net/npm/gsap@3.13.0/dist/gsap.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/gsap@3.13.0/dist/ScrollTrigger.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/gsap@3.13.0/dist/SplitText.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/gsap@3.13.0/dist/DrawSVGPlugin.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/lenis@1.1.14/dist/lenis.min.js"></script>

<!-- ============ MAIN MOTION LAYER ============ -->
<script>
(function () {
  'use strict';

  var reduced     = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var touch       = window.matchMedia('(hover: none), (pointer: coarse)').matches;
  var finePointer = window.matchMedia('(pointer: fine)').matches;
  var isMobile    = window.matchMedia('(max-width: 768px)').matches;
  var $  = function (s, c) { return (c || document).querySelector(s); };
  var $$ = function (s, c) { return Array.prototype.slice.call((c || document).querySelectorAll(s)); };

  document.documentElement.classList.toggle('reduced', reduced);

  var hasGsap = (typeof gsap !== 'undefined') && (typeof ScrollTrigger !== 'undefined');
  if (hasGsap) {
    gsap.registerPlugin(ScrollTrigger, SplitText, DrawSVGPlugin);
    ScrollTrigger.config({ ignoreMobileResize: true });
  }

  /* ---------------- header state (all modes) ---------------- */
  var header = $('.site-header');
  function headState () { if (header) header.classList.toggle('scrolled', window.scrollY > 70); }
  window.addEventListener('scroll', headState, { passive: true });
  headState();

  /* ---------------- Lenis smooth scroll (motion mode only) ---------------- */
  var lenis = null;
  if (!reduced && hasGsap && typeof Lenis !== 'undefined') {
    lenis = new Lenis({ duration: 1.1 });
    window.lenis = lenis; /* QA hook — required */
    lenis.on('scroll', ScrollTrigger.update);
    gsap.ticker.add(function (t) { lenis.raf(t * 1000); });
    gsap.ticker.lagSmoothing(0);
  }

  /* in-page anchors play nice with Lenis */
  $$('a[href^="#"]').forEach(function (a) {
    a.addEventListener('click', function (e) {
      var id = a.getAttribute('href');
      if (!id || id.length < 2) return;
      var target = $(id);
      if (!target) return;
      e.preventDefault();
      if (lenis) lenis.scrollTo(target, { offset: -70 });
      else target.scrollIntoView({ behavior: reduced ? 'auto' : 'smooth' });
    });
  });

  /* ---------------- video plate: plays only in view, never dimmed ---------------- */
  var vid = $('.video-frame video');
  if (vid) {
    if (reduced) {
      vid.removeAttribute('autoplay');
      vid.pause();
      vid.controls = true;
    } else if ('IntersectionObserver' in window) {
      new IntersectionObserver(function (entries) {
        entries.forEach(function (en) {
          if (en.isIntersecting) { var p = vid.play(); if (p && p.catch) p.catch(function () {}); }
          else vid.pause();
        });
      }, { threshold: 0.15 }).observe(vid);
    }
  }

  /* ---------------- hero strikethrough span (injected; CSS shows it struck by default) ---------------- */
  function injectStrike () {
    var gate = $('#gateX');
    if (!gate || gate.querySelector('.strike-line')) return null;
    var s = document.createElement('span');
    s.className = 'strike-line';
    s.setAttribute('aria-hidden', 'true');
    gate.appendChild(s);
    return s;
  }

  /* ================================================================
     IGNITION v2 — LED build (per-segment spacing: a bulb lands EXACTLY
     on every gable apex; the center-gable bulb sits at (500,130))
  ================================================================ */
  var SVG_NS    = 'http://www.w3.org/2000/svg';
  var LED_GRADS = { blue: 'url(#g-blue)', white: 'url(#g-white)', silver: 'url(#g-silver)', red: 'url(#g-red)' };
  var CORE_COLS = { blue: '#eaf3ff', white: '#ffffff', silver: '#f2f5fa', red: '#ffd9de' };
  var leds = [];
  var centerIdx = -1;

  function buildLeds () {
    var path = $('#roofPath'), layer = $('#ledLayer');
    if (!path || !layer || !hasGsap) return;
    /* vertices of #roofPath: eave → apex → valley → CENTER apex → valley → apex → eave */
    var V = [[60, 360], [230, 215], [355, 300], [500, 130], [645, 300], [770, 215], [940, 360]];
    var SPACING = 46;
    var pts = [V[0]];
    for (var s = 0; s < V.length - 1; s++) {
      var a = V[s], b = V[s + 1];
      var len = Math.hypot(b[0] - a[0], b[1] - a[1]);
      var n = Math.max(1, Math.round(len / SPACING));
      for (var k = 1; k <= n; k++) {
        pts.push([a[0] + (b[0] - a[0]) * k / n, a[1] + (b[1] - a[1]) * k / n]);
      }
    }
    pts.forEach(function (p, i) {
      if (Math.abs(p[0] - 500) < 0.5 && Math.abs(p[1] - 130) < 0.5) centerIdx = i;
    });

    pts.forEach(function (p, i) {
      var isCenter = (i === centerIdx);
      var g = document.createElementNS(SVG_NS, 'g');
      g.setAttribute('class', 'led' + (isCenter ? ' led-center' : ''));
      g.setAttribute('opacity', '0');
      var halos = {};
      ['blue', 'white', 'silver', 'red'].forEach(function (cName) {
        var h = document.createElementNS(SVG_NS, 'circle');
        h.setAttribute('cx', p[0].toFixed(1)); h.setAttribute('cy', p[1].toFixed(1));
        h.setAttribute('r', isCenter ? '24' : '13');
        h.setAttribute('fill', LED_GRADS[cName]);
        h.setAttribute('opacity', cName === 'blue' ? '1' : '0');
        g.appendChild(h);
        halos[cName] = h;
      });
      var core = document.createElementNS(SVG_NS, 'circle');
      core.setAttribute('class', 'led-core');
      core.setAttribute('cx', p[0].toFixed(1)); core.setAttribute('cy', p[1].toFixed(1));
      core.setAttribute('r', isCenter ? '4.6' : '3');
      core.setAttribute('fill', isCenter ? '#ffffff' : CORE_COLS.blue);
      core.style.animationDelay = (Math.random() * -2.6).toFixed(2) + 's';
      g.appendChild(core);
      layer.appendChild(g);
      leds.push({ g: g, halos: halos, core: core, isCenter: isCenter, order: 0 });
    });
    leds.forEach(function (L, i) { L.order = Math.abs(i - centerIdx); });
  }
  buildLeds();

  /* ---------------- LED color modes + chase ---------------- */
  var chaseTls = [];
  function killChase () { chaseTls.forEach(function (t) { t.kill(); }); chaseTls = []; }

  function tintLed (L, cName, dur, delay) {
    ['blue', 'white', 'silver', 'red'].forEach(function (n) {
      gsap.to(L.halos[n], { opacity: n === cName ? 1 : 0, duration: dur, delay: delay || 0, ease: 'sine.inOut', overwrite: 'auto' });
    });
    var col = (L.isCenter && cName !== 'red') ? '#ffffff' : CORE_COLS[cName];
    gsap.to(L.core, { fill: col, duration: dur, delay: delay || 0, ease: 'sine.inOut', overwrite: 'auto' });
  }

  function setMode (mode) {
    if (!hasGsap || !leds.length) return;
    killChase();
    var animate = !reduced;
    if (mode === 'chase') {
      if (!animate) { /* static chase representation */
        leds.forEach(function (L, i) { tintLed(L, ['blue', 'white', 'silver'][i % 3], 0); });
        return;
      }
      var PH = ['blue', 'white', 'silver'];
      var STEP = 0.6;
      leds.forEach(function (L, i) {
        var tl = gsap.timeline({ repeat: -1 });
        PH.forEach(function (ph, k) {
          ['blue', 'white', 'silver', 'red'].forEach(function (n) {
            tl.to(L.halos[n], { opacity: n === ph ? 1 : 0, duration: STEP * 0.85, ease: 'sine.inOut' }, k * STEP);
          });
          tl.to(L.core, { fill: L.isCenter ? '#ffffff' : CORE_COLS[ph], duration: STEP * 0.85, ease: 'sine.inOut' }, k * STEP);
        });
        tl.progress((i * 0.055) % 1); /* phase offset = the wave flows along the roofline */
        chaseTls.push(tl);
      });
      return;
    }
    leds.forEach(function (L, i) {
      var cName = (mode === 'gameday') ? ['red', 'white', 'blue'][i % 3] : mode;
      tintLed(L, cName, animate ? 0.55 : 0, animate ? i * 0.018 : 0);
    });
  }

  var chips = $$('#modeRow .chip');
  var userPicked = false;
  function pressChip (mode) {
    chips.forEach(function (c) { c.setAttribute('aria-pressed', c.dataset.mode === mode ? 'true' : 'false'); });
  }
  chips.forEach(function (chip) {
    chip.addEventListener('click', function () {
      userPicked = true;
      pressChip(chip.dataset.mode);
      setMode(chip.dataset.mode);
    });
  });

  var chaseStarted = false;
  function autoChase () {
    if (chaseStarted || userPicked) return;
    chaseStarted = true;
    pressChip('chase');
    setMode('chase');
  }

  /* ================================================================
     WORKSHEET — real kit pricing, cheapest kit+add-on combo
  ================================================================ */
  var KITS = [
    { ft: 100, price: 1299,   label: '100 ft kit' },
    { ft: 150, price: 1762.5, label: '150 ft kit' },
    { ft: 200, price: 2399,   label: '200 ft kit' },
    { ft: 300, price: 3499,   label: '300 ft kit' }
  ];
  function bestAddons (need) {
    if (need <= 0) return { cost: 0, n50: 0, n25: 0 };
    var best = null;
    var max50 = Math.ceil(need / 50);
    for (var n50 = 0; n50 <= max50; n50++) {
      var rem = need - n50 * 50;
      var n25 = rem > 0 ? Math.ceil(rem / 25) : 0;
      var cost = n50 * 499 + n25 * 299;
      if (!best || cost < best.cost || (cost === best.cost && (n50 + n25) < (best.n50 + best.n25))) {
        best = { cost: cost, n50: n50, n25: n25 };
      }
    }
    return best;
  }
  function cheapestCombo (ft) {
    /* exact kit sizes sell the kit, not a patchwork of add-ons */
    for (var k = 0; k < KITS.length; k++) {
      if (KITS[k].ft === ft) return { total: KITS[k].price, pieces: 1, label: KITS[k].label };
    }
    var best = null;
    KITS.forEach(function (kit) {
      var add = bestAddons(ft - kit.ft);
      var total = kit.price + add.cost;
      var pieces = 1 + add.n50 + add.n25;
      if (!best || total < best.total - 0.001 || (Math.abs(total - best.total) < 0.001 && pieces < best.pieces)) {
        var label = kit.label;
        if (add.n50) label += ' + ' + (add.n50 > 1 ? add.n50 + '× ' : '') + '50 ft add-on';
        if (add.n25) label += ' + ' + (add.n25 > 1 ? add.n25 + '× ' : '') + '25 ft add-on';
        best = { total: total, pieces: pieces, label: label };
      }
    });
    return best;
  }

  var wsEls = {
    ft: $('#wsFt'), rate: $('#wsRate'), gross: $('#wsGross'), mat: $('#wsMat'),
    combo: $('#wsCombo'), profit: $('#wsProfit'), margin: $('#wsMargin'), annual: $('#wsAnnual'),
    range: $('#ftRange'), up: $('#rateUp'), down: $('#rateDown')
  };
  var WS = { ft: 150, rate: 30 };
  var wsCur = { ft: 150, rate: 30, gross: 4500, mat: 1762.5, profit: 2737.5, margin: 60.83, annual: 142350 };
  function nfmt (n) { return Math.round(n).toLocaleString('en-US'); }
  function wsCompute () {
    var combo = cheapestCombo(WS.ft);
    var gross = WS.ft * WS.rate;
    var profit = Math.max(0, gross - combo.total);
    return {
      ft: WS.ft, rate: WS.rate, gross: gross, mat: combo.total, profit: profit,
      margin: gross > 0 ? (profit / gross) * 100 : 0,
      annual: profit * 52, label: combo.label
    };
  }
  function wsRender () {
    if (wsEls.ft)     wsEls.ft.textContent     = Math.round(wsCur.ft) + ' FT';
    if (wsEls.rate)   wsEls.rate.textContent   = '$' + Math.round(wsCur.rate);
    if (wsEls.gross)  wsEls.gross.textContent  = '$' + nfmt(wsCur.gross);
    if (wsEls.mat && wsEls.mat.firstChild) wsEls.mat.firstChild.nodeValue = '−$' + nfmt(Math.floor(wsCur.mat));
    if (wsEls.profit) wsEls.profit.textContent = '$' + nfmt(Math.floor(wsCur.profit));
    if (wsEls.margin) wsEls.margin.textContent = Math.round(wsCur.margin) + '%';
    if (wsEls.annual) wsEls.annual.textContent = '$' + nfmt(wsCur.annual);
  }
  function wsApply (dur) {
    var t = wsCompute();
    if (wsEls.combo) wsEls.combo.textContent = t.label;
    var vals = { ft: t.ft, rate: t.rate, gross: t.gross, mat: t.mat, profit: t.profit, margin: t.margin, annual: t.annual };
    if (!reduced && hasGsap && dur) {
      gsap.to(wsCur, Object.assign({}, vals, {
        duration: dur, ease: 'power2.out', overwrite: true, onUpdate: wsRender, onComplete: wsRender
      }));
    } else {
      Object.assign(wsCur, vals);
      wsRender();
    }
  }
  if (wsEls.range) {
    wsEls.range.addEventListener('input', function () { WS.ft = +wsEls.range.value; wsApply(0.45); });
  }
  function nudgeRate (d) { WS.rate = Math.min(60, Math.max(20, WS.rate + d)); wsApply(0.45); }
  if (wsEls.up)   wsEls.up.addEventListener('click',   function () { nudgeRate(5); });
  if (wsEls.down) wsEls.down.addEventListener('click', function () { nudgeRate(-5); });
  wsApply(0); /* sync render with computed defaults */

  /* ================================================================
     REDUCED MOTION — full static path. No pins, no scrubs, no parallax.
     Markup already carries final copy + counter values.
  ================================================================ */
  if (reduced || !hasGsap) {
    injectStrike(); /* CSS default = struck through */
    if (hasGsap && leds.length) {
      leds.forEach(function (L) { gsap.set(L.g, { opacity: 1 }); });
      gsap.set('#bloomGlow', { opacity: 0.55 });
      gsap.set('#apexLabel', { opacity: 1 });
      gsap.set('.win', { fillOpacity: 0.22 });
      pressChip('blue');
      setMode('blue');
    }
    return;
  }

  /* ================================================================
     FULL MOTION ORCHESTRATION (after fonts, so SplitText measures right)
  ================================================================ */
  document.fonts.ready.then(function () {

    var fmt = function (el, v) {
      return (el.dataset.prefix || '') + Math.round(v).toLocaleString('en-US') + (el.dataset.suffix || '');
    };

    /* ---------- hero intro ---------- */
    var heroSplit = null;
    try { heroSplit = new SplitText('#heroH1', { type: 'words,chars', mask: 'chars' }); } catch (e) { heroSplit = null; }
    var strike = injectStrike();

    var intro = gsap.timeline({ defaults: { ease: 'power4.out' } });
    intro.from('.site-header', { y: -40, autoAlpha: 0, duration: 1 }, 0.1);
    if (heroSplit && heroSplit.chars && heroSplit.chars.length) {
      intro.from(heroSplit.chars, { yPercent: 120, duration: 1.15, stagger: { amount: 0.55 } }, 0.25);
    }
    if (strike) {
      intro.fromTo(strike, { scaleX: 0 }, { scaleX: 1, duration: 0.55, ease: 'power3.inOut' }, 1.05);
    }
    intro
      .from('.hero-label', { autoAlpha: 0, y: 16, duration: 0.7 }, 0.45)
      .from(['.hero-sub', '.hero-ctas', '.hero-meta'], { autoAlpha: 0, y: 28, duration: 0.9, stagger: 0.12 }, 0.95)
      .from('.hero-scroll', { autoAlpha: 0, duration: 0.8 }, 1.5);

    /* ---------- IGNITION v2 — pinned scrub ---------- */
    if (leds.length) {
      var igniteSplit = null;
      try { igniteSplit = new SplitText('#igniteH', { type: 'words,chars', mask: 'chars' }); } catch (e) { igniteSplit = null; }

      var ledGs = leds.map(function (L) { return L.g; });
      gsap.set(ledGs, { scale: 0, opacity: 0, transformOrigin: '50% 50%' });
      gsap.set('#roofPath', { drawSVG: '0%' });
      gsap.set(['.ignite-sub', '.mode-row', '.mode-cap'], { autoAlpha: 0 });
      gsap.set('.ignite-sub', { y: 26 });
      if (igniteSplit && igniteSplit.chars.length) gsap.set(igniteSplit.chars, { yPercent: 115 });

      var maxOrder = 0;
      leds.forEach(function (L) { maxOrder = Math.max(maxOrder, L.order); });
      var LED_T0 = 1.0, LED_STEP = 0.085;
      var centerAt = LED_T0 + (maxOrder + 1) * LED_STEP + 0.18;
      var centerLed = leds[centerIdx] || leds[0];

      var ign = gsap.timeline({
        scrollTrigger: {
          trigger: '.ignite', start: 'top top',
          end: isMobile ? '+=1800' : '+=2600',
          pin: true, scrub: 1, anticipatePin: 1
        },
        defaults: { ease: 'none' }
      });
      ign.to('#roofPath', { drawSVG: '100%', duration: 2 }, 0);
      /* symmetric outside-in: both eaves first, the CENTER apex bulb lands LAST */
      leds.forEach(function (L) {
        if (L.isCenter) return;
        ign.to(L.g, { scale: 1, opacity: 1, duration: 0.26, ease: 'back.out(2.6)' },
          LED_T0 + (maxOrder - L.order) * LED_STEP);
      });
      ign.to(centerLed.g, { scale: 1, opacity: 1, duration: 0.42, ease: 'back.out(3)' }, centerAt)
        .to('#bloomGlow', { opacity: 0.6, duration: 0.9, ease: 'power2.inOut' }, centerAt + 0.08)
        .to('#apexLabel', { opacity: 1, duration: 0.5, ease: 'power2.out' }, centerAt + 0.32)
        .to('.win', { fillOpacity: 0.22, duration: 0.7, ease: 'power2.inOut' }, centerAt + 0.3)
        .call(autoChase, null, centerAt + 0.8);
      if (igniteSplit && igniteSplit.chars.length) {
        ign.to(igniteSplit.chars, { yPercent: 0, duration: 0.8, ease: 'power3.out', stagger: { amount: 0.5 } }, centerAt + 0.8);
      }
      ign.to('.ignite-sub', { autoAlpha: 1, y: 0, duration: 0.6, ease: 'power2.out' }, centerAt + 1.1)
        .to(['.mode-row', '.mode-cap'], { autoAlpha: 1, duration: 0.5, ease: 'power2.out' }, centerAt + 1.3)
        .to({}, { duration: 0.8 }); /* hold the lit house */
    }

    /* ---------- generic reveals (clearProps keeps CSS hover transforms alive) ---------- */
    $$('[data-reveal]').forEach(function (el) {
      gsap.from(el, {
        autoAlpha: 0, y: '+=44', duration: 1.05, ease: 'power3.out',
        clearProps: 'transform,opacity,visibility',
        scrollTrigger: { trigger: el, start: 'top 88%', once: true }
      });
    });

    /* ---------- section headline splits ---------- */
    $$('.h2').forEach(function (h) {
      try {
        var sp = new SplitText(h, { type: 'lines', mask: 'lines' });
        gsap.from(sp.lines, {
          yPercent: 110, duration: 1, ease: 'power4.out', stagger: 0.09,
          scrollTrigger: { trigger: h, start: 'top 86%', once: true }
        });
      } catch (e) { /* headline stays visible */ }
    });

    /* ---------- counters ---------- */
    $$('.counter').forEach(function (el) {
      var target = parseFloat(el.dataset.target);
      if (isNaN(target)) return;
      el.textContent = fmt(el, 0);
      ScrollTrigger.create({
        trigger: el, start: 'top 86%', once: true,
        onEnter: function () {
          var o = { v: 0 };
          gsap.to(o, {
            v: target, duration: 2.4, ease: 'power3.out',
            onUpdate: function () { el.textContent = fmt(el, o.v); }
          });
        }
      });
    });

    /* ---------- worksheet count-in on first sight ---------- */
    if ($('.ws-panel')) {
      ScrollTrigger.create({
        trigger: '.ws-panel', start: 'top 80%', once: true,
        onEnter: function () {
          var t = wsCompute();
          gsap.fromTo(wsCur, { gross: 0, mat: 0, profit: 0, margin: 0, annual: 0 }, {
            gross: t.gross, mat: t.mat, profit: t.profit, margin: t.margin, annual: t.annual,
            duration: 1.6, ease: 'power2.out', onUpdate: wsRender, onComplete: wsRender
          });
        }
      });
    }

    /* ---------- image parallax ---------- */
    $$('.plx').forEach(function (wrapEl) {
      var img = wrapEl.querySelector('img');
      if (!img) return;
      gsap.fromTo(img, { yPercent: -6 }, {
        yPercent: 6, ease: 'none',
        scrollTrigger: { trigger: wrapEl, start: 'top bottom', end: 'bottom top', scrub: true }
      });
    });

    /* ---------- SPOTLIGHT REVEAL — cursor sweeps the light, scroll switches it on ---------- */
    (function () {
      var section = $('#spotSection'), stage = $('#spotStage'), maskEl = $('#spotMask');
      var bloom = $('#spotBloom'), glow = $('#spotGlow'), copy = $('#spotCopy'), hint = $('#spotHint');
      if (!section || !stage || !maskEl) return;

      var sx = 0, sy = 0, tx = 0, ty = 0, progress = 0, lit = false, inView = false;
      var t0 = performance.now();

      function vmax () { return Math.max(window.innerWidth, window.innerHeight); }
      function easeInOut (p) { return p < 0.5 ? 2 * p * p : 1 - Math.pow(-2 * p + 2, 2) / 2; }
      function applyLight () {
        var radius = (0.11 + easeInOut(progress) * 1.65) * vmax();
        var m = 'radial-gradient(circle ' + radius.toFixed(1) + 'px at ' + sx.toFixed(1) + 'px ' + sy.toFixed(1) +
                'px, rgba(0,0,0,1) 30%, rgba(0,0,0,.45) 62%, rgba(0,0,0,0) 100%)';
        maskEl.style.webkitMaskImage = m;
        maskEl.style.maskImage = m;
        if (glow) {
          var gr = Math.max(120, radius * 0.5);
          glow.style.background = 'radial-gradient(circle ' + gr.toFixed(1) + 'px at ' + sx.toFixed(1) + 'px ' + sy.toFixed(1) +
            'px, rgba(125,184,255,' + (0.15 * Math.max(0, 1 - progress * 0.8)).toFixed(3) + '), rgba(30,127,255,0.04) 55%, rgba(0,0,0,0) 78%)';
        }
      }
      function resetCenter () {
        var r = stage.getBoundingClientRect();
        tx = sx = r.width * 0.5; ty = sy = r.height * 0.45;
        applyLight();
      }
      resetCenter();
      window.addEventListener('resize', resetCenter);

      if (!touch) {
        stage.addEventListener('mousemove', function (e) {
          var r = stage.getBoundingClientRect();
          tx = e.clientX - r.left; ty = e.clientY - r.top;
        });
      }

      ScrollTrigger.create({
        trigger: section, start: 'top top', end: '+=170%',
        pin: true, scrub: 0.4, anticipatePin: 1,
        onUpdate: function (self) { progress = self.progress; },
        onToggle: function (self) { inView = self.isActive; }
      });

      /* slow Ken Burns drift on the photo */
      gsap.fromTo('#spotImg', { scale: 1.06 }, { scale: 1.14, duration: 22, ease: 'sine.inOut', yoyo: true, repeat: -1 });

      gsap.ticker.add(function () {
        if (!inView) return;
        if (touch) { /* automatic slow sweep on touch devices */
          var r = stage.getBoundingClientRect();
          var t = (performance.now() - t0) / 1000;
          tx = r.width  * (0.5  + 0.36 * Math.sin(t * 0.45));
          ty = r.height * (0.42 + 0.20 * Math.sin(t * 0.3 + 1.7));
        }
        sx += (tx - sx) * 0.085;
        sy += (ty - sy) * 0.085;
        applyLight();
        if (copy) copy.style.opacity = Math.min(1, 0.16 + progress * 1.25);
        if (hint) hint.style.opacity = Math.max(0, 1 - progress * 2.4);

        var nowLit = progress > 0.82;
        if (nowLit && !lit) {
          lit = true;
          if (bloom) gsap.timeline()
            .fromTo(bloom, { opacity: 0 }, { opacity: 0.5, duration: 0.55, ease: 'power2.out' })
            .to(bloom, { opacity: 0.16, duration: 1.1, ease: 'power2.inOut' });
        } else if (!nowLit && lit) {
          lit = false;
          if (bloom) gsap.to(bloom, { opacity: 0, duration: 0.5, overwrite: true });
        }
      });
    })();

    /* ---------- THE PROGRAM — $20K strike → page-filling $0 (pinned scrub) ---------- */
    (function () {
      var zs = $('#zeroStage');
      if (!zs) return;
      gsap.set('.zero-label', { autoAlpha: 0, y: 18 });
      gsap.set('#zeroOld',    { autoAlpha: 0, y: 24 });
      gsap.set('#zeroNum',    { autoAlpha: 0, scale: 0.32, transformOrigin: '50% 60%' });
      gsap.set('#zeroSub',    { autoAlpha: 0, y: 26 });

      gsap.timeline({
        scrollTrigger: { trigger: zs, start: 'top top', end: '+=1800', pin: true, scrub: 0.8, anticipatePin: 1 },
        defaults: { ease: 'none' }
      })
        .to('.zero-label', { autoAlpha: 1, y: 0, duration: 0.35 }, 0)
        .to('#zeroOld', { autoAlpha: 1, y: 0, duration: 0.45 }, 0.15)
        .to('#gateStrike', { scaleX: 1, duration: 0.5, ease: 'power2.inOut' }, 0.75)
        .to('#gateStrike2', { scaleX: 1, duration: 0.45, ease: 'power2.inOut' }, 0.95)
        .to('#zeroNum', { autoAlpha: 1, scale: 1, duration: 1.3, ease: 'power2.out' }, 1.15)
        .to('#zeroOld', { autoAlpha: 0.3, duration: 0.4 }, 1.3)
        .to('#zeroSub', { autoAlpha: 1, y: 0, duration: 0.5, ease: 'power2.out' }, 2.2)
        .to({}, { duration: 0.6 });
    })();

    /* ---------- finale ---------- */
    try {
      var finSplit = new SplitText('#finalH', { type: 'chars', mask: 'chars' });
      gsap.from(finSplit.chars, {
        yPercent: 120, duration: 1.1, ease: 'power4.out', stagger: { amount: 0.5 },
        scrollTrigger: { trigger: '#finalH', start: 'top 82%', once: true }
      });
    } catch (e) { /* headline stays visible */ }

    gsap.from(['.final-sub', '.final-ctas', '.final-brand', '.final-micro'], {
      autoAlpha: 0, y: 30, duration: 1, ease: 'power3.out', stagger: 0.12,
      scrollTrigger: { trigger: '.final', start: 'top 70%', once: true }
    });
    if ($('#finalMark')) {
      gsap.to('#finalMark', { y: -12, duration: 3, yoyo: true, repeat: -1, ease: 'sine.inOut' });
    }

    /* ---------- magnetic buttons ---------- */
    if (finePointer) {
      $$('.mag').forEach(function (btn) {
        btn.addEventListener('mousemove', function (e) {
          var r = btn.getBoundingClientRect();
          gsap.to(btn, {
            x: (e.clientX - r.left - r.width / 2) * 0.32,
            y: (e.clientY - r.top - r.height / 2) * 0.32,
            duration: 0.4, ease: 'power3.out'
          });
        });
        btn.addEventListener('mouseleave', function () {
          gsap.to(btn, { x: 0, y: 0, duration: 0.7, ease: 'elastic.out(1, 0.45)' });
        });
      });
    }

    /* ---------- custom cursor ---------- */
    if (finePointer) {
      var cur = $('.cursor');
      if (cur) {
        var ctx = innerWidth / 2, cty = innerHeight / 2, cpx = ctx, cpy = cty;
        window.addEventListener('mousemove', function (e) {
          ctx = e.clientX; cty = e.clientY; cur.classList.add('on');
        }, { passive: true });
        document.addEventListener('mouseover', function (e) {
          cur.classList.toggle('grow', !!(e.target.closest && e.target.closest('a, button, input')));
        });
        gsap.ticker.add(function () {
          cpx += (ctx - cpx) * 0.2; cpy += (cty - cpy) * 0.2;
          cur.style.transform = 'translate3d(' + cpx + 'px, ' + cpy + 'px, 0)';
        });
      }
    }

    ScrollTrigger.refresh();
  });

  /* settle layout once images/video have real dimensions */
  window.addEventListener('load', function () {
    if (hasGsap && !reduced) ScrollTrigger.refresh();
  });
})();
</script>

<!-- ============ HERO — THREE.JS PARTICLE RIDGE (module: importmap resolves 'three') ============ -->
<script type="module">
const heroEl = document.querySelector('.hero');
const heroCanvas = document.getElementById('heroCanvas');
const heroReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
const heroMobile = window.matchMedia('(max-width: 768px)').matches;
const heroFine = window.matchMedia('(pointer: fine)').matches;

async function initHeroRidge() {
  let THREE;
  try { THREE = await import('three'); }
  catch (e) { heroEl.classList.add('no-webgl'); return; }

  let renderer;
  try {
    renderer = new THREE.WebGLRenderer({ canvas: heroCanvas, alpha: true, antialias: false, powerPreference: 'high-performance' });
  } catch (e) { heroEl.classList.add('no-webgl'); return; }

  const PR = Math.min(window.devicePixelRatio || 1, 1.5);
  renderer.setPixelRatio(PR);

  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(55, 1, 0.1, 220);
  camera.position.set(0, 0, 52);

  /* ridge shape: triple peak echoing the 3-peak logo mark */
  const PEAKS = [[-34, 9.5, 17], [0, 15.5, 23], [34, 9.5, 17]];
  const ridgeY = (x) => {
    let y = 0.6;
    for (const [cx, h, w] of PEAKS) y = Math.max(y, h * (1 - Math.abs(x - cx) / w));
    return y;
  };

  const COUNT = heroMobile ? 2200 : 9000;
  const pos = new Float32Array(COUNT * 3);
  const col = new Float32Array(COUNT * 3);
  const siz = new Float32Array(COUNT);
  const pha = new Float32Array(COUNT);

  for (let i = 0; i < COUNT; i++) {
    const x = (Math.random() * 2 - 1) * 62;
    const ry = ridgeY(x) + (Math.random() - 0.5) * 0.5;
    const onEdge = Math.random() < 0.38;
    let y;
    if (onEdge) {
      y = ry + (Math.random() - 0.5) * 0.9;            // dense glowing ridge line
    } else {
      const t = Math.pow(Math.random(), 1.7);          // body fading downward
      y = ry - t * (ry + 9);
    }
    const z = (Math.random() * 2 - 1) * 9;
    pos[i * 3] = x; pos[i * 3 + 1] = y; pos[i * 3 + 2] = z;

    /* blue / ice / white only — no warm tones */
    const ice = Math.random() < 0.12;
    const m = onEdge ? 0.75 + Math.random() * 0.45 : 0.35 + Math.random() * 0.5;
    if (ice) { col[i * 3] = 0.85 * m; col[i * 3 + 1] = 0.92 * m; col[i * 3 + 2] = 1.0 * m; }
    else     { col[i * 3] = 0.12 * m; col[i * 3 + 1] = 0.5 * m;  col[i * 3 + 2] = 1.0 * m; }

    siz[i] = (onEdge ? 1.9 + Math.random() * 2.3 : 0.8 + Math.random() * 1.5) * (ice ? 1.3 : 1);
    pha[i] = Math.random() * Math.PI * 2;
  }

  const geo = new THREE.BufferGeometry();
  geo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
  geo.setAttribute('aColor', new THREE.BufferAttribute(col, 3));
  geo.setAttribute('aSize', new THREE.BufferAttribute(siz, 1));
  geo.setAttribute('aPhase', new THREE.BufferAttribute(pha, 1));

  const mat = new THREE.ShaderMaterial({
    uniforms: { uTime: { value: 0 }, uPR: { value: PR } },
    vertexShader: `
      attribute float aSize;
      attribute float aPhase;
      attribute vec3  aColor;
      uniform float uTime;
      uniform float uPR;
      varying vec3  vColor;
      varying float vTw;
      void main(){
        vec3 p = position;
        p.y += sin(uTime * 0.55 + aPhase) * 0.4;
        p.x += cos(uTime * 0.35 + aPhase * 1.71) * 0.3;
        vec4 mv = modelViewMatrix * vec4(p, 1.0);
        gl_PointSize = aSize * uPR * (320.0 / -mv.z);
        vColor = aColor;
        vTw = 0.72 + 0.28 * sin(uTime * 0.9 + aPhase * 2.7);
        gl_Position = projectionMatrix * mv;
      }`,
    fragmentShader: `
      precision mediump float;
      varying vec3  vColor;
      varying float vTw;
      void main(){
        float d = length(gl_PointCoord - vec2(0.5));
        float a = smoothstep(0.5, 0.04, d);
        a *= a;
        gl_FragColor = vec4(vColor * (1.05 + 0.5 * vTw), a * (0.45 + 0.55 * vTw));
      }`,
    transparent: true,
    depthWrite: false,
    blending: THREE.AdditiveBlending
  });

  const points = new THREE.Points(geo, mat);
  points.position.y = -22;
  scene.add(points);

  function size() {
    const w = heroCanvas.clientWidth, h = heroCanvas.clientHeight;
    renderer.setSize(w, h, false);
    camera.aspect = w / h;
    camera.updateProjectionMatrix();
  }
  size();

  /* mouse parallax — deliberately more pronounced than concept 1, still smooth */
  let mx = 0, my = 0, cx = 0, cy = 0;
  if (!heroReduced && !heroMobile && heroFine) {
    window.addEventListener('mousemove', (e) => {
      mx = (e.clientX / window.innerWidth) * 2 - 1;
      my = (e.clientY / window.innerHeight) * 2 - 1;
    }, { passive: true });
  }

  /* pause when the hero scrolls offscreen */
  let onScreen = true;
  if ('IntersectionObserver' in window) {
    new IntersectionObserver((en) => { onScreen = en[0].isIntersecting; }, { threshold: 0 }).observe(heroCanvas);
  }

  function draw(time) {
    cx += (mx - cx) * 0.05;
    cy += (my - cy) * 0.05;
    camera.position.x = cx * 6.5;
    camera.position.y = cy * -3.0;
    camera.lookAt(0, -10, 0);
    mat.uniforms.uTime.value = time;
    renderer.render(scene, camera);
  }
  function render(time) {
    if (document.hidden || !onScreen) return;
    draw(time);
  }

  draw(12.5); /* paint a first frame immediately */

  if (heroReduced) {
    window.addEventListener('resize', () => { size(); draw(12.5); });
  } else {
    if (window.gsap) {
      gsap.ticker.add(render); /* consolidated loop */
    } else {
      const loop = (t) => { render(t / 1000); requestAnimationFrame(loop); };
      requestAnimationFrame(loop);
    }
    window.addEventListener('resize', size);
  }
  heroEl.classList.add('webgl-ready');
}

if (heroEl && heroCanvas) {
  initHeroRidge().catch(() => heroEl.classList.add('no-webgl'));
}
</script>

