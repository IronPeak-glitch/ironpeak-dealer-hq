  .site-header nav a{ color:var(--body); text-decoration:none; font-size:.85rem; letter-spacing:.08em; text-transform:uppercase; font-family:var(--disp); }
  .site-header nav a:hover{ color:var(--ink); }
  .btn{ display:inline-flex; align-items:center; gap:.5rem; font-family:var(--disp); font-weight:600; letter-spacing:.06em; text-transform:uppercase; text-decoration:none; cursor:pointer; border:0; }
  .btn-primary{ background:linear-gradient(135deg, var(--blue), var(--blue-deep)); color:#fff; padding:.8rem 1.4rem; font-size:.85rem; }
  .btn-primary:hover{ filter:brightness(1.1); }
  .btn-sm{ padding:.55rem 1rem; font-size:.75rem; }

  .page-head{ padding:4.5rem 0 2rem; }
  .kicker{ font-family:var(--disp); font-size:.7rem; letter-spacing:.32em; text-transform:uppercase; color:var(--blue); }
